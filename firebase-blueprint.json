{
  "entities": {
    "QuizResult": {
      "title": "Quiz Result",
      "description": "A record of a student's quiz performance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentName": { "type": "string" },
        "studentEmail": { "type": "string" },
        "moduleTitle": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "studentEmail", "moduleTitle", "score", "total", "timestamp"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "preferredLanguage": { "type": "string", "enum": ["en", "ml"] },
        "preferredScreenReader": { "type": "string" }
      },
      "required": ["uid", "email", "fullName", "role"]
    },
    "Module": {
      "title": "Module",
      "description": "A learning module containing lessons and a quiz",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "level": { "type": "string", "enum": ["basic", "advanced"] },
        "title": {
          "type": "object",
          "properties": {
            "en": { "type": "string" },
            "ml": { "type": "string" }
          }
        },
        "description": {
          "type": "object",
          "properties": {
            "en": { "type": "string" },
            "ml": { "type": "string" }
          }
        },
        "lessons": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "object" },
              "content": { "type": "object" },
              "videoUrl": { "type": "string" },
              "audioUrl": { "type": "string" }
            }
          }
        },
        "quiz": { "type": "array" },
        "order": { "type": "integer" },
        "imageUrl": { "type": "string" }
      },
      "required": ["category", "level", "title", "lessons", "quiz"]
    },
    "UserProgress": {
      "title": "User Progress",
      "description": "Tracks a student's progress in a module",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "moduleId": { "type": "string" },
        "completedLessons": { "type": "array", "items": { "type": "string" } },
        "quizCompleted": { "type": "boolean" },
        "quizScore": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "moduleId", "completedLessons", "quizCompleted", "lastUpdated"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/modules/{moduleId}": {
      "schema": "Module",
      "description": "Learning module documents."
    },
    "/quiz_results/{resultId}": {
      "schema": "QuizResult",
      "description": "Student quiz results."
    },
    "/user_progress/{progressId}": {
      "schema": "UserProgress",
      "description": "User progress documents."
    }
  }
}
